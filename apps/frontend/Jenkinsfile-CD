pipeline {
    agent any

    options {
        disableConcurrentBuilds()
        timeout(time: 20, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '5'))
    }

    environment {
        SERVICE_NAME = 'frontend'
        SERVICE_DIR = 'apps/frontend'
        DOCKER_IMAGE = 'ghadabannourii/smartsite-frontend'
        K8S_NAMESPACE = 'default'
        DOCKER_REGISTRY = 'docker.io'
    }

    tools {
        nodejs 'NodeJS-20'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                echo "✅ Code récupéré pour le déploiement"
            }
        }

        stage('Build Docker Image') {
            steps {
                dir("${SERVICE_DIR}") {
                    script {
                        def imageTag = "${BUILD_NUMBER}"
                        def imageName = "${DOCKER_IMAGE}:${imageTag}"
                        
                        sh """
                            docker build -t ${imageName} .
                            docker tag ${imageName} ${DOCKER_IMAGE}:latest
                        """
                        
                        env.DOCKER_IMAGE_TAG = imageTag
                        echo "✅ Image Docker construite: ${imageName}"
                    }
                }
            }
        }

        stage('Push to Registry') {
            steps {
                script {
                    withCredentials([usernamePassword(credentialsId: 'docker-hub-credentials', 
                                                   usernameVariable: 'DOCKER_USER', 
                                                   passwordVariable: 'DOCKER_PASS')]) {
                        sh """
                            echo \$DOCKER_PASS | docker login -u \$DOCKER_USER --password-stdin
                            docker push ${DOCKER_IMAGE}:${env.DOCKER_IMAGE_TAG}
                            docker push ${DOCKER_IMAGE}:latest
                        """
                    }
                    echo "✅ Image pushée vers Docker Hub"
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                script {
                    sh """
                        if ! kubectl get deployment frontend -n ${K8S_NAMESPACE} > /dev/null 2>&1; then
                            echo "Deployment inexistant, application du manifest..."
                            kubectl apply -f ${SERVICE_DIR}/k8s/deployment.yaml
                        fi

                        kubectl set image deployment/frontend \
                            frontend=${DOCKER_IMAGE}:${env.DOCKER_IMAGE_TAG} \
                            -n ${K8S_NAMESPACE}

                        kubectl rollout status deployment/frontend -n ${K8S_NAMESPACE} --timeout=300s
                        kubectl get pods -l app=frontend -n ${K8S_NAMESPACE}
                    """
                    echo "✅ Service déployé sur Kubernetes"
                }
            }
        }

        stage('Health Check') {
            steps {
                script {
                    sleep(time: 30, unit: 'SECONDS')
                    
                    sh """
                        # Vérifier que le service répond
                        kubectl get service frontend -n ${K8S_NAMESPACE}
                        
                        # Test de santé via NodePort
                        NODE_PORT=\$(kubectl get service frontend -n ${K8S_NAMESPACE} -o jsonpath='{.spec.ports[0].nodePort}')
                        echo "Frontend accessible sur le port: \$NODE_PORT"
                        
                        # Test HTTP
                        curl -f http://localhost:\$NODE_PORT || echo "Health check failed"
                    """
                    echo "✅ Vérification de santé terminée"
                }
            }
        }
    }

    post {
        success {
            echo "🎉 Déploiement réussi pour ${SERVICE_NAME} — build #${BUILD_NUMBER}"
            echo "📦 Image: ${DOCKER_IMAGE}:${env.DOCKER_IMAGE_TAG}"
            echo "🌐 Frontend accessible via NodePort 30080"
        }
        failure {
            echo "❌ Déploiement échoué pour ${SERVICE_NAME} — build #${BUILD_NUMBER}"
        }
        always {
            sh 'docker system prune -f || true'
            cleanWs(deleteDirs: true, notFailBuild: true)
        }
    }
}
