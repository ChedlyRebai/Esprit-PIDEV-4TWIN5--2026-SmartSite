pipeline {
    agent {
        label 'any'
    }

    options {
        // Empêcher les builds concurrents
        disableConcurrentBuilds()
        // Timeout global pour éviter les builds bloqués
        timeout(time: 30, unit: 'MINUTES')
        // Garder seulement les 10 derniers builds
        buildDiscarder(logRotator(numToKeepStr: '10'))
        // Permettre la reprise après redémarrage Jenkins
        preserveStashes(buildCount: 5)
    }

    environment {
        SERVICE_NAME  = 'frontend'
        SERVICE_DIR   = 'apps/frontend'
        SONAR_PROJECT = 'smartsite-frontend'
        // Augmenter le timeout npm
        NPM_CONFIG_FETCH_TIMEOUT = '300000'
        NPM_CONFIG_FETCH_RETRIES = '5'
    }

    tools {
        nodejs 'NodeJS-20'
    }

    stages {

        stage('Checkout') {
            steps {
                script {
                    // Retry en cas d'échec du checkout
                    retry(3) {
                        checkout scm
                    }
                }
                echo "✅ Code récupéré depuis GitHub"
            }
        }

        stage('Install Dependencies') {
            steps {
                dir("${SERVICE_DIR}") {
                    script {
                        // Retry avec timeout pour npm ci
                        retry(2) {
                            timeout(time: 10, unit: 'MINUTES') {
                                sh 'npm ci --prefer-offline --no-audit'
                            }
                        }
                    }
                    echo "✅ Dépendances installées"
                }
            }
        }

        stage('Unit Tests') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh 'npm test -- --coverage'
                    echo "✅ Tests unitaires terminés"
                }
            }
        }

        stage('Build') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh 'npm run build'
                    echo "✅ Build terminé"
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir("${SERVICE_DIR}") {
                    script {
                        try {
                            withSonarQubeEnv('SonarQube') {
                                withEnv(["PATH+SONAR=${tool 'SonarScanner'}/bin"]) {
                                    sh """
                                        sonar-scanner \
                                            -Dsonar.projectKey=${SONAR_PROJECT} \
                                            -Dsonar.projectName='SmartSite - Frontend' \
                                            -Dsonar.sources=src \
                                            -Dsonar.exclusions=**/*.test.tsx,**/*.test.ts,**/node_modules/**,**/dist/**,**/build/** \
                                            -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info \
                                            -Dsonar.typescript.lcov.reportPaths=coverage/lcov.info \
                                            -Dsonar.coverage.exclusions=**/*.test.tsx,**/*.test.ts,**/node_modules/**,**/dist/**,**/build/**
                                    """
                                }
                            }
                            echo "✅ SonarQube analysis completed"
                        } catch (Exception e) {
                            echo "⚠️ SonarQube analysis failed but continuing pipeline: ${e.message}"
                        }
                    }
                }
            }
        }

        stage('Trigger CD') {
            steps {
                build job: 'frontend-CD', wait: false
                echo "🚀 Pipeline CD déclenché automatiquement"
            }
        }
    }

    post {
        success {
            script {
                def serviceName = env.SERVICE_NAME ?: 'frontend'
                echo "🎉 CI réussi pour ${serviceName} — build #${BUILD_NUMBER}"
            }
        }
        failure {
            script {
                def serviceName = env.SERVICE_NAME ?: 'frontend'
                echo "❌ CI échoué pour ${serviceName} — build #${BUILD_NUMBER}"
            }
        }
        always {
            script {
                // Nettoyage sécurisé même après perte de contexte
                try {
                    cleanWs(
                        deleteDirs: true,
                        disableDeferredWipeout: true,
                        notFailBuild: true
                    )
                } catch (Exception e) {
                    echo "⚠️ Nettoyage workspace échoué (non bloquant): ${e.message}"
                }
            }
        }
    }
}
