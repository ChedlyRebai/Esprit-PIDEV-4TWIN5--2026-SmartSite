pipeline {
    agent any

    environment {
        SERVICE_NAME  = 'frontend'
        SERVICE_DIR   = 'apps/frontend'
        SONAR_PROJECT = 'smartsite-frontend'
    }

    tools {
        nodejs 'NodeJS-20'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
                echo "✅ Code récupéré depuis GitHub"
            }
        }

        stage('Install Dependencies') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh 'npm ci'
                    echo "✅ Dépendances installées"
                }
            }
        }

        stage('Unit Tests') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh 'npm test -- --run --coverage'
                    echo "✅ Tests unitaires terminés"
                }
            }
        }

        stage('Build') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh 'npm run build'
                    echo "✅ Build terminé"
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir("${SERVICE_DIR}") {
                    script {
                        try {
                            withSonarQubeEnv('SonarQube') {
                                withEnv(["PATH+SONAR=${tool 'SonarScanner'}/bin"]) {
                                    sh """
                                        sonar-scanner \
                                            -Dsonar.projectKey=${SONAR_PROJECT} \
                                            -Dsonar.projectName='SmartSite - Frontend' \
                                            -Dsonar.sources=src \
                                            -Dsonar.exclusions=**/*.test.tsx,**/*.test.ts,**/node_modules/**,**/dist/**,**/build/** \
                                            -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info \
                                            -Dsonar.typescript.lcov.reportPaths=coverage/lcov.info \
                                            -Dsonar.coverage.exclusions=**/*.test.tsx,**/*.test.ts,**/node_modules/**,**/dist/**,**/build/**
                                    """
                                }
                            }
                            echo "✅ SonarQube analysis completed"
                        } catch (Exception e) {
                            echo "⚠️ SonarQube analysis failed but continuing pipeline: ${e.message}"
                        }
                    }
                }
            }
        }

        stage('Trigger CD') {
            steps {
                build job: 'frontend-CD', wait: false
                echo "🚀 Pipeline CD déclenché automatiquement"
            }
        }
    }

    post {
        success {
            echo "🎉 CI réussi pour ${SERVICE_NAME} — build #${BUILD_NUMBER}"
        }
        failure {
            echo "❌ CI échoué pour ${SERVICE_NAME} — build #${BUILD_NUMBER}"
        }
        always {
            cleanWs()
        }
    }
}
