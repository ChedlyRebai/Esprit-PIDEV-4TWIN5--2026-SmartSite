pipeline {
    agent any

    options {
        timestamps()
        timeout(time: 1, unit: 'HOURS')
        buildDiscarder(logRotator(numToKeepStr: '10'))
        skipDefaultCheckout(true)
    }

    environment {
        REGISTRY = 'docker.io'
        REGISTRY_CREDENTIALS = 'docker-hub'
        DOCKER_USERNAME = 'chedlyrebai'
        PLANNING_IMAGE = "${REGISTRY}/${DOCKER_USERNAME}/user-authentication-api"

        SONAR_HOST_URL = 'http://localhost:9000'
        SONAR_PROJECT_KEY = 'pidev-users-auth'
    }

    stages {
        stage('Clean workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout') {
            steps {
                checkout([
                    $class: 'GitSCM',
                    branches: [[name: '*/devops']],
                    userRemoteConfigs: [[
                        url: 'https://github.com/ChedlyRebai/Esprit-PIDEV-4TWIN5--2026-SmartSite.git',
                        credentialsId: 'pidev-github-credentials'
                    ]]
                ])

                script {
                    env.GIT_COMMIT_SHORT = sh(
                        script: 'git rev-parse --short HEAD',
                        returnStdout: true
                    ).trim()

                    env.GIT_BRANCH = sh(
                        script: 'git rev-parse --abbrev-ref HEAD',
                        returnStdout: true
                    ).trim()

                    echo "Branch: ${env.GIT_BRANCH}"
                    echo "Commit: ${env.GIT_COMMIT_SHORT}"
                }
            }
        }

        stage('Build & Test') {
            steps {
                dir('apps/backend/user-authentication') {
                    sh 'npm install'
                    sh 'npm run test:cov'
                    echo 'Tests and coverage generated'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sq1') {
                    withCredentials([string(credentialsId: 'pidev-users-auth', variable: 'SONAR_LOGIN')]) {
                        script {
                            def scannerHome = tool 'SonarScanner'

                            sh '''
                                cd apps/backend/user-authentication

                                ''' + scannerHome + '''/bin/sonar-scanner \
                                -Dsonar.projectKey=pidev-users-auth \
                                -Dsonar.projectName="SmartSite - Gestion users" \
                                -Dsonar.sources=src \
                                -Dsonar.tests=src \
                                -Dsonar.test.inclusions=**/*.spec.ts \
                                -Dsonar.exclusions=**/node_modules/**,**/dist/** \
                                -Dsonar.coverage.exclusions=**/*.spec.ts,**/*.module.ts \
                                -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info \
                                -Dsonar.host.url=$SONAR_HOST_URL \
                            '''
                        }
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 15, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }
    }
}
