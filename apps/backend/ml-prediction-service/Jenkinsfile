pipeline {
    agent any

    environment {
        SERVICE_NAME  = 'ml-prediction-service'
        SERVICE_DIR   = 'apps/backend/ml-prediction-service'
        SONAR_PROJECT = 'smartsite-ml-prediction-service'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
                echo "✅ Code récupéré depuis GitHub"
            }
        }

        stage('Install Dependencies') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh 'python3 -m pip install --break-system-packages -r requirements.txt'
                    echo "✅ Dépendances Python installées"
                }
            }
        }

        stage('Unit Tests') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh 'python3 -m pytest test_main.py -v --junitxml=test-results.xml'
                    echo "✅ Tests unitaires terminés"
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir("${SERVICE_DIR}") {
                    script {
                        try {
                            withSonarQubeEnv('SonarQube') {
                                withEnv(["PATH+SONAR=${tool 'SonarScanner'}/bin"]) {
                                    sh """
                                        sonar-scanner \
                                            -Dsonar.projectKey=${SONAR_PROJECT} \
                                            -Dsonar.projectName='SmartSite - ML Prediction Service' \
                                            -Dsonar.sources=. \
                                            -Dsonar.exclusions=**/__pycache__/**,**/venv/**,**/test_*.py \
                                            -Dsonar.python.version=3.14
                                    """
                                }
                            }
                            echo "✅ SonarQube analysis completed"
                        } catch (Exception e) {
                            echo "⚠️ SonarQube analysis failed but continuing pipeline: ${e.message}"
                        }
                    }
                }
            }
        }

        stage('Trigger CD') {
            steps {
                build job: 'ml-prediction-service-CD', wait: false
                echo "🚀 Pipeline CD déclenché automatiquement"
            }
        }
    }

    post {
        success {
            echo "🎉 CI réussi pour ${SERVICE_NAME} — build #${BUILD_NUMBER}"
        }
        failure {
            echo "❌ CI échoué pour ${SERVICE_NAME} — build #${BUILD_NUMBER}"
        }
        always {
            cleanWs()
        }
    }
}
