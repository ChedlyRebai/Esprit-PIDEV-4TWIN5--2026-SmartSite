pipeline {
    agent {
        label 'any'
    }

    options {
        disableConcurrentBuilds()
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
        preserveStashes(buildCount: 5)
    }

    environment {
        SERVICE_NAME  = 'ml-prediction-service'
        SERVICE_DIR   = 'apps/backend/ml-prediction-service'
        SONAR_PROJECT = 'smartsite-ml-prediction-service'
        PIP_TIMEOUT = '300'
        PIP_RETRIES = '5'
    }

    stages {

        stage('Checkout') {
            steps {
                script {
                    retry(3) {
                        checkout scm
                    }
                }
                echo "✅ Code récupéré depuis GitHub"
            }
        }

        stage('Install Dependencies') {
            steps {
                dir("${SERVICE_DIR}") {
                    script {
                        retry(2) {
                            timeout(time: 10, unit: 'MINUTES') {
                                sh '''
                                    python3 -m venv venv
                                    . venv/bin/activate
                                    pip install --upgrade pip
                                    pip install -r requirements.txt
                                '''
                            }
                        }
                    }
                    echo "✅ Dépendances Python installées dans venv"
                }
            }
        }

        stage('Unit Tests') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh '''
                        . venv/bin/activate
                        pytest test_main.py -v --junitxml=test-results.xml
                    '''
                    echo "✅ Tests unitaires terminés"
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir("${SERVICE_DIR}") {
                    script {
                        try {
                            withSonarQubeEnv('SonarQube') {
                                withEnv(["PATH+SONAR=${tool 'SonarScanner'}/bin"]) {
                                    sh """
                                        sonar-scanner \
                                            -Dsonar.projectKey=${SONAR_PROJECT} \
                                            -Dsonar.projectName='SmartSite - ML Prediction Service' \
                                            -Dsonar.sources=. \
                                            -Dsonar.exclusions=**/__pycache__/**,**/venv/**,**/test_*.py \
                                            -Dsonar.python.version=3.14
                                    """
                                }
                            }
                            echo "✅ SonarQube analysis completed"
                        } catch (Exception e) {
                            echo "⚠️ SonarQube analysis failed but continuing pipeline: ${e.message}"
                        }
                    }
                }
            }
        }

        stage('Trigger CD') {
            steps {
                build job: 'ml-prediction-service-CD', wait: false
                echo "🚀 Pipeline CD déclenché automatiquement"
            }
        }
    }

    post {
        success {
            script {
                def serviceName = env.SERVICE_NAME ?: 'ml-prediction-service'
                echo "🎉 CI réussi pour ${serviceName} — build #${BUILD_NUMBER}"
            }
        }
        failure {
            script {
                def serviceName = env.SERVICE_NAME ?: 'ml-prediction-service'
                echo "❌ CI échoué pour ${serviceName} — build #${BUILD_NUMBER}"
            }
        }
        always {
            script {
                try {
                    cleanWs(
                        deleteDirs: true,
                        disableDeferredWipeout: true,
                        notFailBuild: true
                    )
                } catch (Exception e) {
                    echo "⚠️ Nettoyage workspace échoué (non bloquant): ${e.message}"
                }
            }
        }
    }
}
