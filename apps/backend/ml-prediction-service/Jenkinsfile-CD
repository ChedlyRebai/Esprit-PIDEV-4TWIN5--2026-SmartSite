pipeline {
    agent any

    environment {
        SERVICE_NAME  = 'ml-prediction-service'
        SERVICE_DIR   = 'apps/backend/ml-prediction-service'
        DOCKER_IMAGE  = "ghada/smartsite-ml-prediction-service"
        PORT          = '8000'
        DOCKER_HOST   = 'unix:///var/run/docker.sock'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
                echo "✅ Code récupéré depuis GitHub"
            }
        }

        stage('Docker Build') {
            steps {
                dir("${SERVICE_DIR}") {
                    script {
                        // Utiliser l'agent Docker directement via le plugin
                        docker.build("${DOCKER_IMAGE}:${BUILD_NUMBER}", "--no-cache .")
                        docker.build("${DOCKER_IMAGE}:latest", "--no-cache .")
                        echo "✅ Image Docker construite : ${DOCKER_IMAGE}:${BUILD_NUMBER}"
                    }
                }
            }
        }

        stage('Docker Push') {
            steps {
                script {
                    try {
                        docker.withRegistry('https://registry.hub.docker.com', 'docker-hub-credentials') {
                            def image = docker.image("${DOCKER_IMAGE}:${BUILD_NUMBER}")
                            image.push()
                            def latestImage = docker.image("${DOCKER_IMAGE}:latest")
                            latestImage.push()
                        }
                        echo "✅ Image Docker poussée sur Docker Hub"
                    } catch (Exception e) {
                        echo "⚠️ Docker Hub push échoué (credentials manquants?) - On continue..."
                    }
                }
            }
        }

        stage('Deploy') {
            steps {
                script {
                    // Arrêter et supprimer le conteneur existant
                    sh "docker stop ${SERVICE_NAME} || true"
                    sh "docker rm ${SERVICE_NAME} || true"
                    
                    // Déployer avec le plugin Docker
                    docker.image("${DOCKER_IMAGE}:latest").run(
                        "--name ${SERVICE_NAME} " +
                        "--restart unless-stopped " +
                        "-p ${PORT}:${PORT} " +
                        "-e PORT=${PORT}"
                    )
                    echo "✅ ${SERVICE_NAME} déployé sur le port ${PORT}"
                }
            }
        }

        stage('Health Check') {
            steps {
                script {
                    sleep(time: 10, unit: 'SECONDS')
                    def response = sh(
                        script: "curl -s -o /dev/null -w '%{http_code}' http://localhost:${PORT}/ || echo '000'",
                        returnStdout: true
                    ).trim()
                    
                    if (response == '200') {
                        echo "✅ Health check réussi - Service opérationnel"
                    } else {
                        echo "⚠️ Health check échoué - Code HTTP: ${response}"
                    }
                }
            }
        }
    }

    post {
        success {
            echo "🎉 CD réussi — ${SERVICE_NAME} déployé (build #${BUILD_NUMBER})"
            echo "🌐 Service accessible sur: http://localhost:${PORT}"
        }
        failure {
            echo "❌ CD échoué pour ${SERVICE_NAME} — build #${BUILD_NUMBER}"
            script {
                try {
                    sh "docker start ${SERVICE_NAME} || true"
                } catch (Exception e) {
                    echo "⚠️ Impossible de redémarrer le service"
                }
            }
        }
        always {
            script {
                try {
                    sh "docker image prune -f || true"
                } catch (Exception e) {
                    echo "⚠️ Nettoyage des images ignoré"
                }
            }
            cleanWs()
        }
    }
}
