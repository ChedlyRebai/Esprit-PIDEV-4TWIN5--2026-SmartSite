pipeline {
    agent any

    options {
        timestamps()
        timeout(time: 1, unit: 'HOURS')
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    environment {
        REGISTRY = 'docker.io'
        REGESTRY_CREDENTIALS = 'docker-hub'
        DOCKER_USERNAME = 'chedlyrebai'
        PLANNING_IMAGE = "${REGISTRY}/${DOCKER_USERNAME}/planning-api"
        SONARQUEBE_HOST = 'http://localhost:9000'
        SONAR_PROJECT_KEY = 'pidev-key'
        SONAR_LOGIN = credentials('pidev-key')
        TAG_NUMBER = 50
    }

    stages {
        stage('Clean worspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout') {
            steps {
                checkout([
            $class: 'GitSCM',
            branches: [[name: '*/feat/api-gateway']],
            userRemoteConfigs: [[
                url: 'https://github.com/ChedlyRebai/Esprit-PIDEV-4TWIN5--2026-SmartSite.git',
                credentialsId: 'pidev-github-credentials'
            ]]
        ])

                script {
                    env.GIT_COMMIT_SHORT = sh(
                script: 'git rev-parse --short HEAD',
                returnStdout: true
            ).trim()

                    env.GIT_BRANCH = sh(
                script: 'git rev-parse --abbrev-ref HEAD',
                returnStdout: true
            ).trim()

                    echo "Branch: ${env.GIT_BRANCH}"
                    echo "Commit: ${env.GIT_COMMIT_SHORT}"
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv(installationName: 'sq1') {
                    withCredentials([string(credentialsId: 'pidev-sonar', variable: 'SONAR_LOGIN')]) {
                        sh '''
                            sonar-scanner \
                                -Dsonar.projectKey=$SONAR_PROJECT_KEY \
                                -Dsonar.sources=. \
                                -Dsonar.host.url=$SONAR_HOST_URL \
                                -Dsonar.login=$SONAR_LOGIN
                        '''
                    }
                }
            }
        }

    // stage('Build Docker Image'){
    //     steps{
    //         sript {
    //             sh '''
    //                 docker build -t ${PLANNING_IMAGE}:${GIT_COMMIT_SHORT} .
    //             '''
    //         }
    //     }
    // }
    }
}
