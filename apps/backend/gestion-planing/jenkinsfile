pipeline {
    agent any

    options {
        timestamps()
        timeout(time: 1, unit: 'HOURS')
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    environment {
        REGISTRY = 'docker.io'
        REGESTRY_CREDENTIALS = 'docker-hub'
        DOCKER_USERNAME = 'chedlyrebai'
        PLANNING_IMAGE = "${REGISTRY}/${DOCKER_USERNAME}/planning-api"
        SONARQUEBE_HOST = 'http://localhost:9000'
        SONAR_PROJECT_KEY = 'pidev-sonar'
        SONAR_LOGIN = credentials('pidev-sonar')
        TAG_NUMBER = 50
    }

    stages {
        stage('Clean worspace') {
            steps {
                cleanWs()
                script {
                    sh 'pipeline started at: $(date)'
                }
            }
        }


        stage('Checkout') {
            steps {
                script {
                    checkout([$class:'GitSCM',
                          branch:[[name:'*/feat/api-gatewway']],
                           userRemoteConfigs:[[
                               url:'https://github.com/ChedlyRebai/Esprit-PIDEV-4TWIN5--2026-SmartSite.git',
                               credentialsId:'pidev-github-credentials'
                           ]]
                      ])
                    GIT_COMMIT_SHORT = sh(script:'git rev-parse --short HEAD', returnStdout:true).trim()
                    GIT_BRANCH = sh(script:'git rev-parse --abbrev-ref HEAD', returnStdout:true).trim()
                    echo "branch ${GIT_BRANCH}"
                    echo "branch ${GIT_COMMIT_SHORT}"
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv(installationName: 'sq1') {  
                    withCredentials([string(credentialsId: 'pidev-sonar', variable: 'SONAR_LOGIN')]) {
                        sh '''
                            sonar-scanner \
                                -Dsonar.projectKey=$SONAR_PROJECT_KEY \
                                -Dsonar.sources=. \
                                -Dsonar.host.url=$SONAR_HOST_URL \
                                -Dsonar.login=$SONAR_LOGIN
                        '''
                    }
                }
            }
        }

        // stage('Build Docker Image'){
        //     steps{
        //         sript {
        //             sh '''
        //                 docker build -t ${PLANNING_IMAGE}:${GIT_COMMIT_SHORT} .
        //             '''
        //         }
        //     }
        // }
    }
}
