pipeline {
    agent any

    environment {
        SERVICE_NAME  = 'resource-optimization'
        SERVICE_DIR   = 'apps/backend/resource-optimization'
        SONAR_PROJECT = 'smartsite-resource-optimization'
        SONAR_URL     = 'http://192.168.199.136:9000'
        DOCKER_IMAGE  = 'smart-site-resource-optimization'
        CD_JOB_NAME   = 'resource-optimization-cd'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
                echo "✅ Code récupéré depuis GitHub"
            }
        }

        stage('Install Dependencies') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh 'npm ci'
                    echo "✅ Dépendances installées"
                }
            }
        }

        stage('Unit Tests') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh 'npm test -- --coverage --coverageReporters=lcov --forceExit || echo "⚠️ Pas de tests configurés"'
                    echo "✅ Tests unitaires terminés"
                }
            }
        }

        stage('Build') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh 'npm run build'
                    echo "✅ Build terminé"
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir("${SERVICE_DIR}") {
                    withSonarQubeEnv('SonarQube') {
                        withEnv(["PATH+SONAR=${tool 'SonarQubeScanner'}/bin"]) {
                            sh """
                                sonar-scanner \
                                    -Dsonar.projectKey=${SONAR_PROJECT} \
                                    -Dsonar.projectName='SmartSite - Resource Optimization' \
                                    -Dsonar.projectVersion=${BUILD_NUMBER} \
                                    -Dsonar.sources=src \
                                    -Dsonar.typescript.tsconfigPath=tsconfig.sonar.json \
                                    -Dsonar.exclusions=**/*.spec.ts,**/node_modules/**,**/dist/** \
                                    -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info \
                                    -Dsonar.coverage.exclusions=**/*.spec.ts,**/node_modules/**,**/dist/**
                            """
                        }
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                script {
                    def taskId = sh(
                        script: "grep 'ceTaskId=' ${SERVICE_DIR}/.scannerwork/report-task.txt | cut -d'=' -f2",
                        returnStdout: true
                    ).trim()
                    echo "📊 SonarQube task ID: ${taskId}"

                    // Récupère les credentials SonarQube depuis la config Jenkins (même config que withSonarQubeEnv)
                    withSonarQubeEnv('SonarQube') {
                        timeout(time: 15, unit: 'MINUTES') {
                            waitUntil(initialRecurrencePeriod: 10000) {
                                def taskStatus = sh(
                                    script: """
                                        curl -s -H "Authorization: Bearer \${SONAR_AUTH_TOKEN}" \
                                        "\${SONAR_HOST_URL}/api/ce/task?id=${taskId}" \
                                        | python3 -c "import sys,json; print(json.load(sys.stdin)['task']['status'])"
                                    """,
                                    returnStdout: true
                                ).trim()
                                echo "⏳ Task status: ${taskStatus}"
                                return taskStatus in ['SUCCESS', 'FAILED', 'CANCELLED']
                            }
                        }

                        def qgStatus = sh(
                            script: """
                                curl -s -H "Authorization: Bearer \${SONAR_AUTH_TOKEN}" \
                                "\${SONAR_HOST_URL}/api/qualitygates/project_status?projectKey=${SONAR_PROJECT}" \
                                | python3 -c "import sys,json; print(json.load(sys.stdin)['projectStatus']['status'])"
                            """,
                            returnStdout: true
                        ).trim()
                        echo "🔍 Quality Gate: ${qgStatus}"

                        if (qgStatus == 'ERROR') {
                            error("❌ Quality Gate FAILED — ${SONAR_URL}/dashboard?id=${SONAR_PROJECT}")
                        }
                        echo "✅ Quality Gate PASSED"
                    }
                }
            }
        }

        stage('Trigger CD') {
            steps {
                echo "🚀 CI passé — déclenchement du pipeline CD (${CD_JOB_NAME})..."
                script {
                    try {
                        build job: "${CD_JOB_NAME}",
                              wait: false,
                              parameters: [
                                  string(name: 'CI_BUILD_NUMBER', value: "${BUILD_NUMBER}")
                              ]
                        echo "✅ Pipeline CD déclenché avec succès"
                    } catch (err) {
                        echo "⚠️ Impossible de déclencher le CD : ${err.message}"
                        echo "👉 Vérifie que le job '${CD_JOB_NAME}' existe dans Jenkins"
                        currentBuild.result = 'UNSTABLE'
                    }
                }
            }
        }
    }

    post {
        success {
            echo "🎉 CI réussi pour ${SERVICE_NAME} — build #${BUILD_NUMBER} — CD en cours..."
        }
        failure {
            echo "❌ CI échoué pour ${SERVICE_NAME} — build #${BUILD_NUMBER} — CD non déclenché"
        }
        always {
            cleanWs()
        }
    }
}
