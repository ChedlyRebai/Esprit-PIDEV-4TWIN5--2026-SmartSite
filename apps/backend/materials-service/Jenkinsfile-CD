pipeline {
    agent any

    options {
        disableConcurrentBuilds()
        timeout(time: 20, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '5'))
    }

    environment {
        SERVICE_NAME = 'materials-service'
        SERVICE_DIR = 'apps/backend/materials-service'
        DOCKER_IMAGE = 'ghadabannourii/smartsite-materials-service'
        K8S_NAMESPACE = 'default'
        DOCKER_REGISTRY = 'docker.io'
    }

    tools {
        nodejs 'NodeJS-20'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                echo "✅ Code récupéré pour le déploiement"
            }
        }

        stage('Build Docker Image') {
            steps {
                dir("${SERVICE_DIR}") {
                    script {
                        def imageTag = "${BUILD_NUMBER}"
                        def imageName = "${DOCKER_IMAGE}:${imageTag}"
                        
                        sh """
                            docker build -t ${imageName} .
                            docker tag ${imageName} ${DOCKER_IMAGE}:latest
                        """
                        
                        env.DOCKER_IMAGE_TAG = imageTag
                        echo "✅ Image Docker construite: ${imageName}"
                    }
                }
            }
        }

        stage('Push to Registry') {
            steps {
                script {
                    withCredentials([usernamePassword(credentialsId: 'docker-hub-credentials', 
                                                   usernameVariable: 'DOCKER_USER', 
                                                   passwordVariable: 'DOCKER_PASS')]) {
                        sh """
                            echo \$DOCKER_PASS | docker login -u \$DOCKER_USER --password-stdin
                            docker push ${DOCKER_IMAGE}:${env.DOCKER_IMAGE_TAG}
                            docker push ${DOCKER_IMAGE}:latest
                        """
                    }
                    echo "✅ Image pushée vers Docker Hub"
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                script {
                    sh """
                        if ! kubectl get deployment materials-service -n ${K8S_NAMESPACE} > /dev/null 2>&1; then
                            echo "Deployment inexistant, application du manifest..."
                            kubectl apply -f ${SERVICE_DIR}/k8s/deployment.yaml
                        fi

                        kubectl set image deployment/materials-service \
                            materials-service=${DOCKER_IMAGE}:${env.DOCKER_IMAGE_TAG} \
                            -n ${K8S_NAMESPACE}

                        kubectl rollout status deployment/materials-service -n ${K8S_NAMESPACE} --timeout=120s || true
                        kubectl get pods -l app=materials-service -n ${K8S_NAMESPACE}
                    """
                    echo "✅ Service déployé sur Kubernetes"
                }
            }
        }

        stage('Health Check') {
            steps {
                script {
                    sleep(time: 30, unit: 'SECONDS')
                    
                    sh """
                        # Vérifier que le service répond
                        kubectl get service materials-service -n ${K8S_NAMESPACE}
                        
                        # Test de santé via port-forward (optionnel)
                        timeout 10s kubectl port-forward service/materials-service 3009:3009 -n ${K8S_NAMESPACE} &
                        sleep 5
                        curl -f http://localhost:3009/health || echo "Health check via port-forward failed"
                        pkill -f "kubectl port-forward" || true
                    """
                    echo "✅ Vérification de santé terminée"
                }
            }
        }
    }

    post {
        success {
            echo "🎉 Déploiement réussi pour ${SERVICE_NAME} — build #${BUILD_NUMBER}"
            echo "📦 Image: ${DOCKER_IMAGE}:${env.DOCKER_IMAGE_TAG}"
        }
        failure {
            echo "❌ Déploiement échoué pour ${SERVICE_NAME} — build #${BUILD_NUMBER}"
        }
        always {
            sh 'docker system prune -f || true'
            cleanWs(deleteDirs: true, notFailBuild: true)
        }
    }
}