pipeline {
    agent any

    options {
        disableConcurrentBuilds()
        timeout(time: 20, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '5'))
    }

    environment {
        SERVICE_NAME = 'materials-service'
        SERVICE_DIR = 'apps/backend/materials-service'
        DOCKER_IMAGE = 'ghadabannourii/smartsite-materials-service'
        K8S_NAMESPACE = 'default'
        DOCKER_REGISTRY = 'docker.io'
    }

    tools {
        nodejs 'NodeJS-20'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                echo "✅ Code récupéré pour le déploiement"
            }
        }

        stage('Build Docker Image') {
            steps {
                dir("${SERVICE_DIR}") {
                    script {
                        def imageTag = "${BUILD_NUMBER}"
                        def imageName = "${DOCKER_IMAGE}:${imageTag}"
                        sh """
                            docker build -t ${imageName} .
                            docker tag ${imageName} ${DOCKER_IMAGE}:latest
                        """
                        env.DOCKER_IMAGE_TAG = imageTag
                        echo "✅ Image Docker construite: ${imageName}"
                    }
                }
            }
        }

        stage('Push to Registry') {
            steps {
                script {
                    withCredentials([usernamePassword(credentialsId: 'docker-hub-credentials',
                                                   usernameVariable: 'DOCKER_USER',
                                                   passwordVariable: 'DOCKER_PASS')]) {
                        sh """
                            echo \$DOCKER_PASS | docker login -u \$DOCKER_USER --password-stdin
                            docker push ${DOCKER_IMAGE}:${env.DOCKER_IMAGE_TAG}
                            docker push ${DOCKER_IMAGE}:latest
                        """
                    }
                    echo "✅ Image pushée vers Docker Hub"
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                script {
                    sh """
                        if ! kubectl get deployment materials-service -n ${K8S_NAMESPACE} > /dev/null 2>&1; then
                            echo "Deployment inexistant, application du manifest..."
                            kubectl apply -f ${SERVICE_DIR}/k8s/deployment.yaml || true
                        fi
                        kubectl set image deployment/materials-service \
                            materials-service=${DOCKER_IMAGE}:${env.DOCKER_IMAGE_TAG} \
                            -n ${K8S_NAMESPACE} || true
                        kubectl get pods -l app=materials-service -n ${K8S_NAMESPACE} || true
                    """
                    echo "✅ Déploiement Kubernetes effectué"
                }
            }
        }
    }

    post {
        success {
            echo "🎉 CD réussi pour ${SERVICE_NAME} — build #${BUILD_NUMBER}"
            echo "📦 Image: ${DOCKER_IMAGE}:${env.DOCKER_IMAGE_TAG ?: BUILD_NUMBER}"
        }
        failure {
            echo "❌ CD échoué pour ${SERVICE_NAME} — build #${BUILD_NUMBER}"
        }
        always {
            sh 'docker system prune -f || true'
            cleanWs(deleteDirs: true, notFailBuild: true)
        }
    }
}
