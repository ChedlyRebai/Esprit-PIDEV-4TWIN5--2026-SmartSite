pipeline {
    agent any

    options {
        disableConcurrentBuilds()
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
        preserveStashes(buildCount: 5)
    }

    environment {
        SERVICE_NAME  = 'materials-service'
        SERVICE_DIR   = 'apps/backend/materials-service'
        SONAR_PROJECT = 'smartsite-materials-service'
        NPM_CONFIG_FETCH_TIMEOUT = '300000'
        NPM_CONFIG_FETCH_RETRIES = '5'
    }

    tools {
        nodejs 'NodeJS-20'
    }

    stages {

        stage('Checkout') {
            steps {
                script {
                    retry(3) {
                        checkout scm
                    }
                }
                echo "✅ Code récupéré depuis GitHub"
            }
        }

        stage('Install Dependencies') {
            steps {
                dir("${SERVICE_DIR}") {
                    script {
                        retry(2) {
                            timeout(time: 10, unit: 'MINUTES') {
                                sh 'npm ci --prefer-offline --no-audit'
                            }
                        }
                    }
                    echo "✅ Dépendances installées"
                }
            }
        }

        stage('Unit Tests') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh 'npm test -- --coverage --coverageReporters=lcov --forceExit'
                    echo "✅ Tests unitaires terminés"
                }
            }
        }

        stage('Build') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh 'npm run build'
                    echo "✅ Build terminé"
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir("${SERVICE_DIR}") {
                    script {
                        try {
                            withSonarQubeEnv('SonarQube') {
                                withEnv(["PATH+SONAR=${tool 'SonarScanner'}/bin"]) {
                                    sh """
                                        sonar-scanner \
                                            -Dsonar.projectKey=${SONAR_PROJECT} \
                                            -Dsonar.projectName='SmartSite - Materials Service' \
                                            -Dsonar.sources=src \
                                            -Dsonar.exclusions=**/*.spec.ts,**/node_modules/**,**/dist/**,**/*.module.ts,src/main.ts,**/*.dto.ts,**/*.entity.ts \
                                            -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info \
                                            -Dsonar.typescript.lcov.reportPaths=coverage/lcov.info \
                                            -Dsonar.coverage.exclusions=**/*.spec.ts,**/*.module.ts,**/node_modules/**,**/dist/**,src/main.ts,**/*.dto.ts,**/*.entity.ts
                                    """
                                }
                            }
                            echo "✅ SonarQube analysis completed"
                        } catch (Exception e) {
                            echo "⚠️ SonarQube analysis failed but continuing pipeline: ${e.message}"
                        }
                    }
                }
            }
        }

        stage('Trigger CD') {
            steps {
                build job: 'materials-service-CD', wait: false
                echo "🚀 Pipeline CD déclenché automatiquement"
            }
        }
    }

    post {
        success {
            script {
                def serviceName = env.SERVICE_NAME ?: 'materials-service'
                echo "🎉 CI réussi pour ${serviceName} — build #${BUILD_NUMBER}"
            }
        }
        failure {
            script {
                def serviceName = env.SERVICE_NAME ?: 'materials-service'
                echo "❌ CI échoué pour ${serviceName} — build #${BUILD_NUMBER}"
            }
        }
        always {
            script {
                try {
                    cleanWs(
                        deleteDirs: true,
                        disableDeferredWipeout: true,
                        notFailBuild: true
                    )
                } catch (Exception e) {
                    echo "⚠️ Nettoyage workspace échoué (non bloquant): ${e.message}"
                }
            }
        }
    }
}
