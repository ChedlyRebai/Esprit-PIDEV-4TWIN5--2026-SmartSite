pipeline {
    agent any

    tools {
        nodejs 'NodeJS'
    }

    environment {
        SERVICE_NAME    = 'gestion-suppliers'
        DOCKER_IMAGE    = "doniamaazoun/${SERVICE_NAME}"
        SONAR_PROJECT   = 'smartsite-gestion-suppliers'
        DOCKERHUB_CREDENTIALS = credentials('dockerhub-credentials')
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('apps/backend/gestion-suppliers') {
                    sh 'npm ci'
                }
            }
        }

        stage('Unit Tests') {
            steps {
                dir('apps/backend/gestion-suppliers') {
                    sh 'npm test -- --coverage --forceExit'
                }
            }
            post {
                always {
                    junit(
                        testResults: 'apps/backend/gestion-suppliers/coverage/*.xml',
                        allowEmptyResults: true
                    )
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir('apps/backend/gestion-suppliers') {
                    withSonarQubeEnv('SonarQube') {
                        script {
                            def scannerHome = tool 'SonarScanner'
                            sh """
                                ${scannerHome}/bin/sonar-scanner \
                                  -Dsonar.projectKey=${SONAR_PROJECT} \
                                  -Dsonar.sources=src \
                                  -Dsonar.exclusions=**/*.spec.ts,**/node_modules/**,**/dist/** \
                                  -Dsonar.tests=src \
                                  -Dsonar.test.inclusions=**/*.spec.ts \
                                  -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info
                            """
                        }
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                echo 'SonarQube analysis sent successfully — Quality Gate check skipped'
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('apps/backend/gestion-suppliers') {
                    script {
                        echo "🐳 Building Docker image: ${DOCKER_IMAGE}:${BUILD_NUMBER}"
                        bat "docker build -t ${DOCKER_IMAGE}:${BUILD_NUMBER} -t ${DOCKER_IMAGE}:latest ."
                    }
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                script {
                    echo "🔐 Logging into Docker Hub..."
                    bat "echo %DOCKERHUB_CREDENTIALS_PSW% | docker login -u %DOCKERHUB_CREDENTIALS_USR% --password-stdin"
                    
                    echo "📤 Pushing Docker image: ${DOCKER_IMAGE}:${BUILD_NUMBER}"
                    bat "docker push ${DOCKER_IMAGE}:${BUILD_NUMBER}"
                    
                    echo "📤 Pushing Docker image: ${DOCKER_IMAGE}:latest"
                    bat "docker push ${DOCKER_IMAGE}:latest"
                    
                    echo "🧹 Logging out from Docker Hub..."
                    bat "docker logout"
                }
            }
        }
    }

    post {
        success {
            echo "✅ CI Pipeline passed for ${SERVICE_NAME} — build #${BUILD_NUMBER}"
            echo "🚀 Triggering CD Pipeline..."
            build job: 'gestion-suppliers-CD', wait: false
        }
        failure {
            echo "❌ CI Pipeline failed for ${SERVICE_NAME} — build #${BUILD_NUMBER}"
        }
        always {
            cleanWs()
        }
    }
}
